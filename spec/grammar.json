        "module",
        "endpoint",
        "function",
        "job",
        "database",
        "cache",
        "bucket",
        "queue"
      ],
      "requiresParent": false
    },
    {
      "kind": "module",
      "tags": [
        "module"
      ],
      "doc": "a code grouping that is not deployable on its own: a package, library, or class that organizes functions",
