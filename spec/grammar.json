{
  "$schema": "./grammar.schema.json",
  "nodeKinds": [
    {
      "kind": "domain",
      "tags": [
        "domain"
      ],
      "doc": "a bounded context / grouping \u2014 the only kind that exists purely to contain others",
      "contains": [
        "domain",
        "service",
        "module",
        "database",
        "cache",
        "bucket",
        "queue",
        "event",
        "external"
      ],
      "requiresParent": false
    },
    {
      "kind": "service",
      "tags": [
        "service"
      ],
      "doc": "a deployable process: API server, worker, consumer",
